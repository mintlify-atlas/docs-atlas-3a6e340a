  "keyFeatures": [
    "700+ pretrained image models (ResNet, EfficientNet, ViT, ConvNeXt, Swin, MaxViT, MobileNet, and more)",
    "Unified create_model / list_models API for loading any architecture",
    "Multi-GPU distributed training script with AMP, EMA, and gradient clipping",
    "Feature extraction without classifier (forward_features, intermediate feature maps)",
    "Hugging Face Hub integration for pushing and pulling model weights",
    "Rich data pipeline with RandAugment, MixUp, CutMix, Random Erasing, AugMix",
    "Extensive optimizer zoo (AdamP, LAMB, LARS, Lion, Muon, NAdamW, MADGRAD, and more)",
    "Flexible LR schedulers (Cosine, Step, Plateau, Poly, Tanh)",
    "ONNX export and validation support",
    "NaFlex variable-resolution dataset and loader support"
  ],
  "publicApiSurface": [
    "timm.create_model(model_name, pretrained, num_classes, ...)",
    "timm.list_models(filter, pretrained)",
    "timm.list_pretrained()",
    "timm.is_model(model_name)",
    "timm.get_pretrained_cfg(model_name)",
    "model.forward_features(x)",
    "model.forward_head(x)",
    "timm.data.create_dataset(name, root, ...)",
    "timm.data.create_loader(dataset, ...)",
    "timm.data.create_transform(input_size, ...)",
    "timm.data.resolve_data_config(model_or_cfg)",
    "timm.data.Mixup(...)",
    "timm.optim.create_optimizer_v2(model, opt, lr, ...)",
    "timm.optim.list_optimizers()",
    "timm.scheduler.create_scheduler_v2(optimizer, sched, ...)",
    "timm.models.push_to_hf_hub(model, repo_id, ...)"
  ]
